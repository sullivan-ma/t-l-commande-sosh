<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#000000">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="15dp" android:gravity="center">
        
        <Button android:id="@+id/btnSearch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="SCANNER LE RÉSEAU" android:backgroundTint="#FF6600" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="15dp">
            <Button android:id="@+id/btnPower" android:layout_width="60dp" android:layout_height="60dp" android:text="⏻" android:backgroundTint="#FF0000" />
            <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Button android:id="@+id/btnMute" android:layout_width="60dp" android:layout_height="60dp" android:text="🔇" android:backgroundTint="#444444" />
        </LinearLayout>

        <GridLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:columnCount="3">
            <View android:layout_width="60dp" android:layout_height="60dp"/><Button android:id="@+id/btnUp" android:text="▲" android:layout_width="80dp" android:layout_height="80dp" android:backgroundTint="#333333"/><View android:layout_width="60dp" android:layout_height="60dp"/>
            <Button android:id="@+id/btnLeft" android:text="◀" android:layout_width="80dp" android:layout_height="80dp" android:backgroundTint="#333333"/><Button android:id="@+id/btnOK" android:text="OK" android:layout_width="80dp" android:layout_height="80dp" android:backgroundTint="#FF6600"/><Button android:id="@+id/btnRight" android:text="▶" android:layout_width="80dp" android:layout_height="80dp" android:backgroundTint="#333333"/>
            <View android:layout_width="60dp" android:layout_height="60dp"/><Button android:id="@+id/btnDown" android:text="▼" android:layout_width="80dp" android:layout_height="80dp" android:backgroundTint="#333333"/><View android:layout_width="60dp" android:layout_height="60dp"/>
        </GridLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:gravity="center">
            <Button android:id="@+id/btnBack" android:text="RETOUR" android:layout_width="120dp" android:layout_height="wrap_content" android:backgroundTint="#444444" android:layout_margin="5dp"/>
            <Button android:id="@+id/btnHome" android:text="MENU" android:layout_width="120dp" android:layout_height="wrap_content" android:backgroundTint="#444444" android:layout_margin="5dp"/>
        </LinearLayout>

        <GridLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:columnCount="3">
            <Button android:id="@+id/btn1" android:text="1" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/>
            <Button android:id="@+id/btn2" android:text="2" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/>
            <Button android:id="@+id/btn3" android:text="3" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/>
            <Button android:id="@+id/btn4" android:text="4" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/>
            <Button android:id="@+id/btn5" android:text="5" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/>
            <Button android:id="@+id/btn6" android:text="6" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/>
            <Button android:id="@+id/btn7" android:text="7" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/>
            <Button android:id="@+id/btn8" android:text="8" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/>
            <Button android:id="@+id/btn9" android:text="9" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/>
            <View android:layout_width="70dp" android:layout_height="60dp"/><Button android:id="@+id/btn0" android:text="0" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/><View android:layout_width="70dp" android:layout_height="60dp"/>
        </GridLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:gravity="center">
            <Button android:id="@+id/btnRewind" android:text="⏪" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/>
            <Button android:id="@+id/btnPlayPause" android:text="⏯" android:layout_width="80dp" android:layout_height="70dp" android:backgroundTint="#444444" android:layout_marginHorizontal="10dp"/>
            <Button android:id="@+id/btnForward" android:text="⏩" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#222222"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:gravity="center">
            <Button android:id="@+id/btnVolUp" android:text="V+" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#333333"/>
            <Button android:id="@+id/btnVolDown" android:text="V-" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#333333" android:layout_marginRight="40dp"/>
            <Button android:id="@+id/btnChUp" android:text="P+" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#333333"/>
            <Button android:id="@+id/btnChDown" android:text="P-" android:layout_width="70dp" android:layout_height="60dp" android:backgroundTint="#333333"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
